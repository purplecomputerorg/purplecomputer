# build-scripts/.env is sourced by flash-all.sh, record-flash.sh, release-iso.sh,
# clean-old-releases.sh, and setup-cloudflare-rules.sh. It is gitignored.
#
# It can be a plain file with the vars below, or a symlink to a central
# machine secrets file so every machine-local secret lives in one place.

# Orders-app flash recording (flash-all.sh, record-flash.sh). Optional: unset
# means flashes are not recorded, everything else still works.
FLASH_LOG_URL=
ADMIN_PASSWORD_PROD=
# Cloudflare Access service token, if the orders admin is behind Access.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Cloudflare R2 / API creds for ISO releases (release-iso.sh etc.).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# The R2 custom domain that serves release objects directly
# (files.purplecomputer.org). The download PAGE is separate: it lives in the
# landing repo and is served by Vercel at downloads.purplecomputer.org.
R2_CUSTOM_DOMAIN=
CF_API_TOKEN=
CF_ZONE_ID=
