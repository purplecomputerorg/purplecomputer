# Copy to build-scripts/.env (gitignored) and fill in. Read by release-iso.sh
# (R2 upload vars, not listed here) and by the flash-recording scripts below
# (flash-all.sh, record-flash.sh), which POST each flashed build to the orders app.

# Orders-app endpoint that receives flash records (the admin flashes API).
FLASH_LOG_URL=https://your-orders-site.example/api/admin/flashes

# Orders-app admin Basic Auth password (any username). Same value the app uses.
ADMIN_PASSWORD=

# Cloudflare Access service token, only needed if the orders admin is behind
# Access. Create it under Zero Trust > Access > Service auth > Service Tokens.
# Leave both blank if Access is not in front of the endpoint.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
