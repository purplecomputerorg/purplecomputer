#!/bin/bash
# Purple Computer X11 Startup
# Simple and reliable - no edge cases

# Log for debugging (view with: cat /tmp/xinitrc.log)
exec >> /tmp/xinitrc.log 2>&1

DEBUG_FLAG=/opt/purple/debug

# Timestamped logging: only active in debug mode
if [ -f "$DEBUG_FLAG" ]; then
    xlog() {
        local msg="[$(date '+%H:%M:%S')] [xinitrc] $1"
        echo "$msg"
        echo "$msg" >> /tmp/purple-boot.log 2>/dev/null
    }
else
    xlog() { :; }
fi

xlog "=== xinitrc started ==="

# Wait for X to initialize
sleep 1
xlog "X server ready (after 1s wait)"

# Clear the underlying VT text buffer. X.Org writes startup messages (version
# info, keymap warnings) to tty1 before switching to graphics mode. Those stay
# in the VT buffer and reappear when X exits (e.g. during shutdown). Clearing
# now while X covers the screen means there's nothing scary underneath.
printf '\033]P02d1b4e\033[H\033[2J\033[?25l' > /dev/tty1 2>/dev/null

# Start PulseAudio (may not auto-start in live boot)
pulseaudio --start --exit-idle-time=-1 2>/dev/null || true

# Disable screen blanking
xset s off -dpms s noblank b off

# Kid-proofing: disable XKB accessibility features
# Sticky keys can be triggered by holding Shift for 5 seconds
# Slow keys can be triggered by holding Shift for 8 seconds
# These would confuse kids and make typing unpredictable
if command -v xkbset &>/dev/null; then
    xkbset -a  # Disable all AccessX features
fi

# Keyboard repeat (faster for kids)
xset r rate 300 30

# SPICE agent for VM resize (harmless on real hardware)
command -v spice-vdagent &>/dev/null && spice-vdagent &

# Set root window background color
xsetroot -solid "#2d1b4e"

# Hide the mouse cursor globally (keyboard-only UI, no mouse needed).
# XFixesHideCursor is display-global: no window can override it, unlike xsetroot.
# Requires libxfixes3 (explicitly listed in golden image packages).
python3 -c "
from ctypes import cdll, c_ulong
X = cdll.LoadLibrary('libX11.so.6')
Xf = cdll.LoadLibrary('libXfixes.so.3')
d = X.XOpenDisplay(None)
assert d, 'Failed to open X display'
X.XDefaultRootWindow.restype = c_ulong
Xf.XFixesHideCursor(d, X.XDefaultRootWindow(d))
X.XFlush(d)
" 2>/dev/null || xlog "Failed to hide mouse cursor"

# Window manager (required for fullscreen)
matchbox-window-manager -use_titlebar no &
sleep 0.5
xlog "matchbox-window-manager started"

# Prevent HiDPI scaling surprises
export WINIT_X11_SCALE_FACTOR=1.0

# Software GL rendering: works on any GPU (no driver/firmware dependencies).
# For a TUI, software GL is indistinguishable from hardware GL.
export LIBGL_ALWAYS_SOFTWARE=1

# Debug mode: extra diagnostics at boot
if [ -f "$DEBUG_FLAG" ]; then
    xlog "--- Display diagnostics (debug mode) ---"
    echo "xrandr:"
    xrandr 2>&1 | head -20
    echo "Xft.dpi:"
    xrdb -query 2>&1 | grep -i dpi || echo "  (none set)"
    echo "GDK_SCALE=$GDK_SCALE QT_SCALE_FACTOR=$QT_SCALE_FACTOR"
    echo "WINIT_X11_SCALE_FACTOR=$WINIT_X11_SCALE_FACTOR"
    echo "LIBGL_ALWAYS_SOFTWARE=$LIBGL_ALWAYS_SOFTWARE"
    python3 /opt/purple/calc_font_size.py --info 2>&1 || echo "calc_font_size.py --info failed"
    # GL driver info
    echo "GL renderer:"
    if command -v glxinfo &>/dev/null; then
        glxinfo 2>/dev/null | grep -iE 'renderer|vendor|version|string' | sed 's/^/  /'
    else
        echo "  (glxinfo not installed)"
    fi
    xlog "--- End display diagnostics ---"
fi

# Best-guess font size (the app auto-corrects on startup via font_sizer.py)
FONT_SIZE=$(python3 /opt/purple/calc_font_size.py 2>/dev/null || echo "16")
xlog "Font size: $FONT_SIZE"

# Copy config to writable location so the app can adjust font size at runtime.
# Alacritty watches this file and auto-reloads on changes.
ALACRITTY_CONFIG="/tmp/purple-alacritty.toml"
cp /etc/purple/alacritty.toml "$ALACRITTY_CONFIG"
export PURPLE_ALACRITTY_CONFIG="$ALACRITTY_CONFIG"

# Write initial font size into the config file (not -o flag, which would
# override the file and prevent font_sizer.py from adjusting at runtime)
sed -i "s/^size = .*/size = ${FONT_SIZE}/" "$ALACRITTY_CONFIG"

# Debug mode: log terminal size after launch
if [ -f "$DEBUG_FLAG" ]; then
    (
        sleep 3
        xlog "--- Terminal size check (3s after launch) ---"
        if command -v xdotool &>/dev/null; then
            WID=$(xdotool search --name "Alacritty" 2>/dev/null | head -1)
            if [ -n "$WID" ]; then
                xdotool getwindowgeometry "$WID" 2>&1
            else
                echo "  Alacritty window not found!"
            fi
        fi
        xlog "--- End terminal size check ---"
    ) >> /tmp/xinitrc.log 2>&1 &
fi

xlog "Launching Alacritty..."
alacritty --config-file "$ALACRITTY_CONFIG" \
    -e /usr/local/bin/purple
ALACRITTY_EXIT=$?
xlog "Alacritty exited with code $ALACRITTY_EXIT"

# After Purple exits
if [ -f "$DEBUG_FLAG" ]; then
    # Debug: drop to interactive debug shell
    xlog "Opening debug shell"
    sed -i 's/^size = .*/size = 16.0/' "$ALACRITTY_CONFIG"
    exec alacritty --config-file "$ALACRITTY_CONFIG" \
        -e bash --rcfile /opt/purple/debug-shell.sh
else
    # Production: restart Purple
    xlog "Restarting xinitrc"
    exec "$0"
fi
